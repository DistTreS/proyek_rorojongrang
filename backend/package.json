{
  "name": "akademik-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "lint": "eslint .",
    "db:create": "sequelize-cli db:create",
    "db:drop": "sequelize-cli db:drop",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "test": "jest --testPathPatterns=tests/unit_test --runInBand",
    "test:watch": "jest --testPathPatterns=tests/unit_test --runInBand --watch",
    "test:coverage": "jest --testPathPatterns=tests/unit_test --runInBand --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/unit_test/**/*.test.js"],
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "models/**/*.js",
      "utils/**/*.js",
      "!models/index.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov"]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.4",
    "pdfkit": "^0.15.2",
    "sequelize": "^6.37.3",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.2"
  }
}
